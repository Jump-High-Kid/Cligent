{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Cligent FastAPI (run.py)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["run.py"],
      "port": 8000
    },
    {
      "name": "Cligent FastAPI (uvicorn direct)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    }
  ]
}

# 이 파일을 .env로 복사 후 값을 채워주세요: cp .env.example .env

# Claude API 키 — console.anthropic.com에서 발급
ANTHROPIC_API_KEY=sk-ant-여기에_API_키_입력

# JWT 서명 키 — 랜덤 32자 이상. 생성 명령: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=여기에_랜덤_시크릿_키_입력

# 실행 환경 (dev / prod) — prod이면 쿠키에 Secure 플래그 자동 추가
ENV=dev

# ── 어드민 시크릿 ─────────────────────────────────────────────────
# /api/admin/* 엔드포인트 인증. python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=여기에_랜덤_어드민_시크릿_입력

# ── 어드민 클리닉 / 사용자 ID ─────────────────────────────────────
# scripts/create_clinic.py 로 어드민 클리닉 생성 후 반환된 ID 기입
ADMIN_CLINIC_ID=1
ADMIN_USER_ID=1

# ── 베타 신청 알림 수신 이메일 ────────────────────────────────────
ADMIN_NOTIFY_EMAIL=your-email@example.com

# ── 서비스 기본 URL ───────────────────────────────────────────────
BASE_URL=https://cligent.kr

# ── SMTP (Gmail App Password 권장) ───────────────────────────────
# Gmail 앱 비밀번호: Google 계정 > 보안 > 2단계 인증 > 앱 비밀번호
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=여기에_앱_비밀번호_16자리
NOTIFY_FROM=your-email@gmail.com

# ── 네이버 검색 API (블로그 발행 확인 자동화) ─────────────────────
# 발급: https://developers.naver.com/apps/#/register (검색 API 선택)
NAVER_CLIENT_ID=여기에_네이버_클라이언트_ID
NAVER_CLIENT_SECRET=여기에_네이버_클라이언트_시크릿

# ── 한국수출입은행 환율 API (어드민 비용 KPI USD→KRW 환산) ────────
# 발급: https://www.koreaexim.go.kr/ir/HPHKIR020M01 (회원가입 → API 신청 → 키 발급, 무료)
# 미설정·실패 시 config.yaml pricing.usd_to_krw_fallback (기본 1400원) 사용 — 서비스 영향 없음
KOREAEXIM_API_KEY=여기에_수출입은행_API_키_입력
